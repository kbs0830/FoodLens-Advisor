### .env.example
# 在此檔案複製為 `.env`，並填入要使用的 Hugging Face repo id（若想使用 Food-101 預訓練權重）
# 範例: FOOD_MODEL_REPO=owner/repo
# 若不設定，伺服器端會回退到 ImageNet 預訓練的 ResNet50（可用但非 Food-101 精準）

# 可選環境變數
# 指定 Hugging Face repo id（應包含可載入的 pytorch 權重檔與 labels.txt）
FOOD_MODEL_REPO=

# 指定 YOLO 權重（現有檔案 yolov8n.pt 可保留）
YOLO_WEIGHTS_PATH=yolov8n.pt

# 推薦：若有 GPU，啟用 CUDA（預設由 PyTorch 自動偵測）
# 例如在 windows powershell 中啟動 venv 後：
# setx FOOD_MODEL_REPO "owner/repo"

# 注意：實際使用公開 Hugging Face repo 時，請確認該 repo 包含以下檔案：
# - 權重檔 (eg. model.pth, best.pt, pytorch_model.bin)
# - labels.txt（每行一個類別，若為 Food-101 應包含 101 類）

# 我可以替你搜尋公開的 Food-101 預訓練模型並自動填入 `FOOD_MODEL_REPO`，
# 或由你提供 repo id。我有能力直接下載並測試（你的環境有 CUDA）。
VISION_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
ALLOWED_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
